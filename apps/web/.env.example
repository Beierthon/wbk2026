# WBK 2026 Web-App — gleiche Vision-Variablen wie Root-.env.example
# Kopieren: cp apps/web/.env.example apps/web/.env.local
# OpenAI-Vision Preset: cp .env.vision-openai.example apps/web/.env.local
# Vollständiger Guide: docs/entwicklung.md

NEXT_PUBLIC_SUPABASE_URL=https://kjjrmuuhzibtwouaxabg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# mock (Preview/Demo) | supabase (Production) — siehe docs/deployment.md
WBK_DATA_SOURCE=supabase

# =============================================================================
# Vision — Preset A (Standard): Browser COCO-SSD + Server-Mock fuer Demo-Scan
# =============================================================================
WBK_VISION_MODE=mock
NEXT_PUBLIC_WBK_VISION_USE_BROWSER=true

# =============================================================================
# Vision — Preset B: OpenAI Server-Vision — siehe /.env.vision-openai.example
# =============================================================================

WBK_OPENAI_MODEL=gpt-4o
WBK_VISION_FALLBACK_TO_MOCK=true
OPENAI_API_KEY=

# =============================================================================
# LiveKit — WebRTC vision stream (required for Live-Objekterkennung panel)
# =============================================================================
# Server-only: from LiveKit Cloud → Settings → Keys (same key pair)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Public WebSocket URL for livekit-client
NEXT_PUBLIC_LIVEKIT_URL=wss://wbk2026-6wqxexnw.livekit.cloud
