{
  "name": "slides",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev --port 3030 --base /slides/",
    "build": "rm -rf ../web/public/slides && slidev build --base /slides/ --router-mode hash --out ../web/public/slides",
    "export": "slidev export",
    "lint": "echo \"No lint configured for slides\"",
    "typecheck": "echo \"No typecheck configured for slides\""
  },
  "dependencies": {
    "@slidev/cli": "^52.12.0",
    "@slidev/theme-default": "^0.25.0"
  }
}
