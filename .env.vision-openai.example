# WBK 2026 — OpenAI Vision Preset (kopierfertig)
#
# Aktivieren:
#   cp .env.vision-openai.example .env.local
#   cp .env.vision-openai.example apps/web/.env.local
#   # OPENAI_API_KEY unten eintragen
#   pnpm dev
#
# Zurueck zu Browser COCO-SSD:
#   cp .env.example .env.local
#   cp apps/web/.env.example apps/web/.env.local

# --- Supabase (optional; Mock-Daten reichen fuer Vision-Demo) ---
NEXT_PUBLIC_SUPABASE_URL=https://kjjrmuuhzibtwouaxabg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

WBK_DATA_SOURCE=mock

# Server analysiert Kamera-, Upload- und Demo-Scans per OpenAI Vision API.
WBK_VISION_MODE=openai
NEXT_PUBLIC_WBK_VISION_USE_BROWSER=false

# Pflicht: API-Key von https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vision-faehiges Modell (gpt-4o, gpt-4.1, o4-mini, …)
WBK_OPENAI_MODEL=gpt-4o

# Bei API-Fehler auf ERP-Mock zurueckfallen (false = Fehler anzeigen)
WBK_VISION_FALLBACK_TO_MOCK=true

# --- LiveKit WebRTC (Live-Objekterkennung Panel auf /bau) ---
# LiveKit Cloud → Settings → Keys (API Key + Secret, gleiches Paar)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=wss://wbk2026-6wqxexnw.livekit.cloud
