# WBK 2026 — Umgebungsvariablen (ohne Secrets)
# Kopieren: cp .env.example .env.local && cp apps/web/.env.example apps/web/.env.local
# OpenAI-Vision Preset: cp .env.vision-openai.example .env.local (und nach apps/web/.env.local)
# Vollständiger Guide: docs/entwicklung.md

# --- Supabase (öffentlich, Client-Bundle) ---
# Dashboard → Project Settings → API
# Siehe docs/supabase.md und Issues #5, #18, #19
NEXT_PUBLIC_SUPABASE_URL=https://kjjrmuuhzibtwouaxabg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- App-Modi ---
# Datenquelle: supabase (Standard wenn Keys gesetzt) | mock (Offline/Demo)
# Lokal: mock oder supabase | Vercel Preview: mock | Vercel Production: supabase
# Siehe docs/deployment.md
WBK_DATA_SOURCE=supabase

# =============================================================================
# Vision — Preset A (Standard): Browser COCO-SSD + Server-Mock fuer Demo-Scan
# =============================================================================
# Kamera/Bild-Upload: TensorFlow.js COCO-SSD im Browser (kein API-Key noetig).
# Demo-Scan ohne Kamera: Server-Mock mit ERP-Beispielmaterialien.
WBK_VISION_MODE=mock
NEXT_PUBLIC_WBK_VISION_USE_BROWSER=true

# =============================================================================
# Vision — Preset B: OpenAI Server-Vision (API-Key erforderlich)
# =============================================================================
# Schnell aktivieren:
#   1. cp .env.vision-openai.example .env.local
#   2. cp .env.vision-openai.example apps/web/.env.local
#   3. OPENAI_API_KEY eintragen
#   4. pnpm dev neu starten
#
# Oder diese Zeilen manuell setzen (beide Dateien identisch halten):
# WBK_VISION_MODE=openai
# NEXT_PUBLIC_WBK_VISION_USE_BROWSER=false
# OPENAI_API_KEY=sk-proj-...
# WBK_OPENAI_MODEL=gpt-4o

# --- Vision (Server-API unter /api/vision/inspect) ---
WBK_OPENAI_MODEL=gpt-4o
WBK_VISION_FALLBACK_TO_MOCK=true
OPENAI_API_KEY=

# --- LiveKit WebRTC (Live-Objekterkennung Panel) ---
# LiveKit Cloud → Settings → Keys (API Key + Secret)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=wss://wbk2026-6wqxexnw.livekit.cloud

# --- CLI / CI (optional, nie ins Client-Bundle) ---
# SUPABASE_ACCESS_TOKEN=   # supabase login oder Dashboard → Access Tokens
# SUPABASE_PROJECT_REF=kjjrmuuhzibtwouaxabg
# SUPABASE_DB_PASSWORD=    # nur wenn Pooler-Login der CLI fehlschlägt
