# Supabase — https://supabase.com/dashboard/project/kjjrmuuhzibtwouaxabg
# See docs/supabase.md for CLI setup, linking, and migration workflow.

NEXT_PUBLIC_SUPABASE_URL=https://kjjrmuuhzibtwouaxabg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# App data layer: supabase (default when NEXT_PUBLIC_SUPABASE_* is set) | mock
WBK_DATA_SOURCE=supabase

# Vision API: mock | openai
WBK_VISION_MODE=mock
WBK_OPENAI_MODEL=gpt-5.5
WBK_VISION_FALLBACK_TO_MOCK=true
OPENAI_API_KEY=

# CLI (optional — supabase login stores token in macOS Keychain)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=kjjrmuuhzibtwouaxabg
# SUPABASE_DB_PASSWORD=
