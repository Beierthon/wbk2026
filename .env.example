# Datenquelle: "mock" (Standard, ohne Backend) oder "supabase"
WBK_DATA_SOURCE=mock

# Supabase (nur nötig, wenn WBK_DATA_SOURCE=supabase)
# Öffentliche Werte – dürfen im Client-Bundle landen.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Geheim – ausschließlich serverseitig verwenden, niemals als NEXT_PUBLIC_* exponieren.
# SUPABASE_SECRET_KEY=
